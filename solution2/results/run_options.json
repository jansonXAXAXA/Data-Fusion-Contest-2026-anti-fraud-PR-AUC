{
  "input_path": "../data/datasets/full.parquet",
  "output_dir": "../runs/train_last_n_pooling_demo/v3/{date}/{time}",
  "cv_mode": "sliding",
  "train_final_model": false,
  "random_state": 42,
  "threads": 8,
  "gpu": true,
  "history_windows": [
    3,
    10,
    30,
    100
  ],
  "future_windows": [
    3,
    10,
    30,
    100
  ],
  "last_n": 128,
  "max_pred_seq_len": 256,
  "max_epochs": 50,
  "patience": 6,
  "lr": 0.0003,
  "weight_decay": 0.0001,
  "dropout": 0.15,
  "hidden_dim": 128,
  "event_dim": 32,
  "sliding_train_months": 3,
  "batch_size_cpu": 16,
  "batch_size_gpu": 256,
  "grad_clip": 1.0,
  "train_ap_every_n_epochs": 3,
  "aux_loss_weight_suspicious": 0.5,
  "aux_loss_weight_red_yellow": 0.5,
  "multitask_inference_blend": 0.0,
  "use_session_branch": true,
  "session_branch_weight": 0.5,
  "use_future_branches": true,
  "future_max_hours": 24.0,
  "future_branch_weight": 0.5,
  "one_hot_max_cardinality": 32,
  "target1_sample_frac": 0.05,
  "use_label_history": true
}